cat > .gitignore << 'EOF'
# Virtual Environments
venv/
.venv/
UV-Venv/
env/
myenv/
my-venv/
Python/UV-Venv/
Python/venv/
Langchain/my-venv/
Langgraph/venv/

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Mac files
.DS_Store
.DS_Store?

# Environment variables
.env
.env.local

# Large model files
*.bin
*.pt
*.pkl
*.h5

# Jupyter checkpoints
.ipynb_checkpoints/
EOF